@model List<PerformansSitesi.Domain.Entities.Donem>
@{
    ViewData["Title"] = "Dönem Yönetimi";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0">Dönem Yönetimi</h4>
    <a class="btn btn-primary" asp-action="Create">Yeni Dönem</a>
</div>

<table class="table table-sm table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Ad</th>
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th>Aktif</th>
            <th style="width:180px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model)
        {
            <tr>
                <td>@d.Ad</td>
                <td>@d.BaslangicTarihi.ToString("yyyy-MM-dd")</td>
                <td>@d.BitisTarihi.ToString("yyyy-MM-dd")</td>
                <td>
                    @if (d.AktifMi)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </td>
                <td>
                    <a class="btn btn-sm btn-secondary" asp-action="Edit" asp-route-id="@d.DonemId">Düzenle</a>

                    <form asp-action="Delete" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@d.DonemId" />
                        <button class="btn btn-sm btn-danger"
                                type="submit"
                                onclick="return confirm('Bu dönemi silmek istiyor musunuz?');">
                            Sil
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="text-muted" style="font-size:12px;">
    Not: “Aktif” seçilen dönem tek olur. Yeni bir dönemi aktif yaparsanız diğerleri otomatik pasife çekilir.
</div>
