@model PerformansSitesi.Web.ViewModels.PersonelFormViewModel
@{
    ViewData["Title"] = "Yeni Personel";
}

<h4 class="mb-3"><i class="bi bi-person-plus"></i> Yeni Personel</h4>

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">
        <i class="bi bi-exclamation-triangle"></i> @Model.Error
    </div>
}

<form method="post">
    @Html.AntiForgeryToken()

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Sicil No</label>
            <input class="form-control" asp-for="SicilNo" required />
            <span class="text-danger" asp-validation-for="SicilNo"></span>
        </div>

        <div class="col-md-8 mb-3">
            <label class="form-label">Personel Adı Soyadı</label>
            <input class="form-control" asp-for="AdSoyad" required />
            <span class="text-danger" asp-validation-for="AdSoyad"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Görevi</label>
            <input class="form-control" asp-for="Gorev" />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Proje Adı</label>
            <input class="form-control" asp-for="ProjeAdi" />
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Müdürlük</label>
            <input class="form-control" asp-for="Mudurluk" />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">İşe Giriş Tarihi</label>
            <input class="form-control" asp-for="IseGirisTarihi" type="date" />
            <small class="form-text text-muted">Personelin işe başlama tarihi</small>
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">İşten Çıkış Tarihi</label>
            <input class="form-control" asp-for="IstenCikisTarihi" type="date" />
            <small class="form-text text-danger">Girilirse personel otomatik pasif olur</small>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">1. Yönetici (Opsiyonel)</label>
            <select class="form-select" asp-for="Yonetici1Id">
                <option value="">-- Seçiniz --</option>
                @foreach (var y in Model.AllYoneticiler.Where(k => k.Rol == PerformansSitesi.Domain.Enums.Rol.Yonetici1))
                {
                    <option value="@y.KullaniciId">@y.AdSoyad</option>
                }
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">2. Yönetici (Opsiyonel)</label>
            <select class="form-select" asp-for="Yonetici2Id">
                <option value="">-- Seçiniz --</option>
                @foreach (var y in Model.AllYoneticiler.Where(k => k.Rol == PerformansSitesi.Domain.Enums.Rol.Yonetici2))
                {
                    <option value="@y.KullaniciId">@y.AdSoyad</option>
                }
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label class="form-label">Bölge Müdürü (Opsiyonel)</label>
            <select class="form-select" asp-for="NihaiYoneticiId">
                <option value="">-- Seçiniz --</option>
                @foreach (var y in Model.AllYoneticiler.Where(k => k.Rol == PerformansSitesi.Domain.Enums.Rol.NihaiYonetici))
                {
                    <option value="@y.KullaniciId">@y.AdSoyad</option>
                }
            </select>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">
            <i class="bi bi-save"></i> Kaydet
        </button>
        <a class="btn btn-outline-secondary" asp-action="Index">
            <i class="bi bi-x-circle"></i> İptal
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
