@{
    ViewData["Title"] = "Kullanim Kilavuzu";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-book"></i> 
                        @if (ViewBag.UserRole == "SistemAdmin")
                        {
                            <text>Sistem Admin Kullanim Kilavuzu</text>
                        }
                        else if (ViewBag.UserRole == "Admin")
                        {
                            <text>Admin Kullanim Kilavuzu</text>
                        }
                        else if (ViewBag.UserRole == "IK")
                        {
                            <text>IK Kullanim Kilavuzu</text>
                        }
                        else if (ViewBag.UserRole == "Yonetici1")
                        {
                            <text>Yonetici 1 Kullanim Kilavuzu</text>
                        }
                        else if (ViewBag.UserRole == "Yonetici2")
                        {
                            <text>Yonetici 2 Kullanim Kilavuzu</text>
                        }
                        else if (ViewBag.UserRole == "NihaiYonetici")
                        {
                            <text>Nihai Yonetici Kullanim Kilavuzu</text>
                        }
                        else
                        {
                            <text>Genel Kullanim Kilavuzu</text>
                        }
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        <strong>Bilgi:</strong> Bu sayfa <strong>@ViewBag.UserRole</strong> rolune ozel hazirlanmis kullanim kilavuzunu icermektedir.
                    </div>

                    <!-- Kilavuz Icerigi - SERVER-SIDE RENDERED (NO 3RD PARTY MARKDOWN LIBRARY) -->
                    <div class="kilavuz-content" style="max-height: 800px; overflow-y: auto; padding: 20px;">
                        @Html.Raw(ViewBag.KilavuzContent)
                    </div>
                </div>
                <div class="card-footer text-muted">
                    <div class="row">
                        <div class="col-md-6">
                            <small>
                                <i class="bi bi-calendar"></i> Son Guncelleme: Ocak 2026
                            </small>
                        </div>
                        <div class="col-md-6 text-end">
                            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-sm btn-secondary">
                                <i class="bi bi-arrow-left"></i> Dashboard'a Don
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .kilavuz-content h1 {
        font-size: 2rem;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        color: #2c3e50;
        border-bottom: 2px solid #3498db;
        padding-bottom: 0.5rem;
    }

    .kilavuz-content h2 {
        font-size: 1.5rem;
        margin-top: 1.25rem;
        margin-bottom: 0.75rem;
        color: #34495e;
        border-bottom: 1px solid #95a5a6;
        padding-bottom: 0.25rem;
    }

    .kilavuz-content h3 {
        font-size: 1.25rem;
        margin-top: 1rem;
        margin-bottom: 0.5rem;
        color: #7f8c8d;
    }

    .kilavuz-content h4 {
        font-size: 1.1rem;
        margin-top: 0.75rem;
        margin-bottom: 0.5rem;
        color: #95a5a6;
    }

    .kilavuz-content ul, .kilavuz-content ol {
        margin-left: 1.5rem;
        margin-bottom: 1rem;
    }

    .kilavuz-content li {
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    .kilavuz-content p {
        margin-bottom: 1rem;
        line-height: 1.6;
    }

    .kilavuz-content strong {
        color: #2c3e50;
        font-weight: 600;
    }

    .kilavuz-content em {
        font-style: italic;
        color: #555;
    }

    .kilavuz-content table {
        width: 100%;
        margin-bottom: 1rem;
        border-collapse: collapse;
    }

    .kilavuz-content table th,
    .kilavuz-content table td {
        padding: 0.75rem;
        border: 1px solid #dee2e6;
        text-align: left;
    }

    .kilavuz-content table th {
        background-color: #f8f9fa;
        font-weight: bold;
    }

    .kilavuz-content table tr:nth-child(even) {
        background-color: #f8f9fa;
    }

    .kilavuz-content code {
        background-color: #f8f9fa;
        padding: 0.2rem 0.4rem;
        border-radius: 3px;
        font-family: 'Courier New', monospace;
        font-size: 0.9em;
        color: #e83e8c;
    }

    .kilavuz-content pre {
        background-color: #f8f9fa;
        padding: 1rem;
        border-radius: 5px;
        overflow-x: auto;
        margin-bottom: 1rem;
    }

    .kilavuz-content pre code {
        background-color: transparent;
        padding: 0;
        color: #212529;
    }

    .kilavuz-content blockquote {
        border-left: 4px solid #3498db;
        padding-left: 1rem;
        margin-left: 0;
        color: #7f8c8d;
        font-style: italic;
    }

    .kilavuz-content hr {
        margin: 2rem 0;
        border: 0;
        border-top: 1px solid #dee2e6;
    }

    .kilavuz-content a {
        color: #3498db;
        text-decoration: none;
    }

    .kilavuz-content a:hover {
        text-decoration: underline;
    }

    /* Scrollbar styling */
    .kilavuz-content::-webkit-scrollbar {
        width: 8px;
    }

    .kilavuz-content::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .kilavuz-content::-webkit-scrollbar-thumb {
        background: #888;
        border-radius: 4px;
    }

    .kilavuz-content::-webkit-scrollbar-thumb:hover {
        background: #555;
    }
</style>
