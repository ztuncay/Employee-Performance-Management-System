@model AdminDatabaseViewModel
@{
    ViewData["Title"] = "Veritabani Yonetimi";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>
                <i class="bi bi-database"></i> Veritabani Yonetimi
            </h2>
            <a asp-action="Index" class="btn btn-secondary btn-sm mt-2">
                <i class="bi bi-arrow-left"></i> Geri
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Kullanicilar</h6>
                    <h3 class="text-primary">@Model.Users</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Personeller</h6>
                    <h3 class="text-success">@Model.Personnel</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Degerlendirmeler</h6>
                    <h3 class="text-info">@Model.Evaluations</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Audit Loglari</h6>
                    <h3 class="text-warning">@Model.AuditLogs</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Donemler</h6>
                    <h3 class="text-danger">@Model.Periods</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Sorular</h6>
                    <h3 class="text-secondary">@Model.Questions</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title">Degerlendirme Detaylari</h6>
                    <h3 class="text-muted">@Model.EvaluationDetails</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Tehlikeli Islemler</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>Uyari!</strong> Bu islemler veritabanini tamamen silip yeniden olusturacak. 
                        Tum veriler geri donemsuzce silinecektir.
                    </div>

                    <form asp-action="RebuildDatabase" method="post" class="d-inline">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('TUMU SILMEK ISTEDIGNIZ KESIN MISINIZ? Bu islem geri alinamaz!')">
                            <i class="bi bi-arrow-clockwise"></i> Veritabanini Yeniden Olustur
                        </button>
                    </form>

                    <a asp-action="CodeExecution" class="btn btn-outline-danger ms-2">
                        <i class="bi bi-code-square"></i> Ozel Komut Calistir
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
