@model PerformansSitesi.Web.ViewModels.NihaiListViewModel
@{
    ViewData["Title"] = "Bölge Müdürü Listesi";
}

<h4 class="mb-3">Bölge Müdürü - Performans Listesi</h4>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-md-5">
        <label class="form-label">Dönem</label>
        <select class="form-select" name="donemId">
            @foreach (var d in Model.Donemler)
            {
                <option value="@d.DonemId" selected="@(d.DonemId == Model.DonemId)">@d.Ad</option>
            }
        </select>
    </div>
    <div class="col-md-5">
        <label class="form-label">Arama</label>
        <input class="form-control" name="arama" value="@Model.Arama" placeholder="Ad / Sicil / Müdürlük / Proje / Görev" />
    </div>
    <div class="col-md-2 d-grid">
        <button class="btn btn-secondary" type="submit">Filtrele</button>
    </div>
    <div class="col-12 mt-2">
        <span class="badge bg-light text-dark">Personel Sayısı: @Model.DegerlendirilenSayisi / @Model.ToplamPersonelSayisi</span>
    </div>
</form>

<table class="table table-sm table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>Personel</th>
            <th>Sicil</th>
            <th>Görevi</th>
            <th>Proje</th>
            <th>Müdürlük</th>
            <th>Toplam Puan</th>
            <th>Sonuç</th>
            <th>Durum</th>
            <th style="width:140px;">İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var r in Model.Rows)
        {
            var btn = (r.Durum == 3) ? "Değerlendir" : "Görüntüle";
            <tr>
                <td>@r.PersonelAd</td>
                <td>@r.SicilNo</td>
                <td>@r.Gorev</td>
                <td>@r.ProjeAdi</td>
                <td>@r.Mudurluk</td>
                <td>@(r.ToplamPuan.HasValue? r.ToplamPuan.Value.ToString() : "-")</td>
                <td>@(string.IsNullOrWhiteSpace(r.GenelSonuc) ? "-" : r.GenelSonuc)</td>
                <td><span class="badge bg-@r.DurumCssClass">@r.DurumMetni</span></td>
                <td>
                    <a class="btn btn-sm btn-primary"
                       asp-action="Form"
                       asp-route-donemId="@Model.DonemId"
                       asp-route-personelId="@r.PersonelId">@btn</a>
                </td>
            </tr>
        }
    </tbody>
</table>
