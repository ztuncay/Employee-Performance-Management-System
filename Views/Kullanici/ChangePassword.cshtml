@model PerformansSitesi.Web.ViewModels.KullaniciPasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<h4 class="mb-3">Şifre Değiştir</h4>

<div class="alert alert-info">
    Kullanıcı: <b>@Model.AdSoyad</b>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Hata))
{
    <div class="alert alert-danger">@Model.Hata</div>
}

<form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="KullaniciId" />

    <div class="mb-3">
        <label class="form-label">Yeni Şifre</label>
        <input class="form-control" asp-for="YeniSifre" />
        <span class="text-danger" asp-validation-for="YeniSifre"></span>
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit">Kaydet</button>
        <a class="btn btn-outline-dark" asp-action="Index">İptal</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
