@model PerformansSitesi.Web.ViewModels.KullaniciImportViewModel
@{
    ViewData["Title"] = "Kullanıcı Girişi";
    Layout = "_Layout";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-9">
            <h2><i class="bi bi-file-earmark-arrow-up"></i> Kullanıcı Girişi</h2>
        </div>
        <div class="col-md-3">
            <a asp-action="Index" class="btn btn-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Geri
            </a>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.FatalError))
    {
        <div class="alert alert-danger">
            <strong>Hata!</strong> @Model.FatalError
        </div>
    }

    @if (Model.Warnings.Any())
    {
        <div class="alert alert-warning">
            <strong>Uyarılar:</strong>
            <ul class="mb-0">
                @foreach (var w in Model.Warnings)
                {
                    <li>@w</li>
                }
            </ul>
        </div>
    }

    @if (!Model.PreviewReady)
    {
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">1. Excel Dosyası Yükle</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="ImportPreview" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">Excel Dosyası Seç (.xlsx)</label>
                        <input type="file" class="form-control" name="file" accept=".xlsx,.xls" required />
                        <small class="text-muted d-block mt-2">
                            Excel dosyası şu başlıklara sahip olmalıdır:<br>
                            <strong>Ad | Kullanıcı Adı | Email | Rol</strong>
                        </small>
                    </div>

                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-file-earmark-arrow-up"></i> Dosyayı Yükle
                    </button>
                </form>

                <div class="mt-4">
                    <h6>Rol Seçenekleri:</h6>
                    <ul class="list-unstyled">
                        <li><strong>Yonetici1</strong> - 1. Yönetici</li>
                        <li><strong>Yonetici2</strong> - 2. Yönetici</li>
                        <li><strong>NihaiYonetici</strong> - Bölge Müdürü</li>
                        <li><strong>Admin</strong> - Sistem Yöneticisi</li>
                        <li><strong>IK</strong> - İnsan Kaynakları</li>
                        <li><strong>SistemAdmin</strong> - Sistem Yöneticisi (Tam Erişim)</li>
                    </ul>
                </div>

                <div class="mt-4 alert alert-info">
                    <h6>Örnek Excel Formatı:</h6>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Ad</th>
                                <th>Kullanıcı Adı</th>
                                <th>Email</th>
                                <th>Rol</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Zeynep Tuncay</td>
                                <td>ztuncay</td>
                                <td>ztuncay@example.com</td>
                                <td>Yonetici1</td>
                            </tr>
                            <tr>
                                <td>Ahmet Kaya</td>
                                <td>akaya</td>
                                <td>ahmet@example.com</td>
                                <td>Yonetici2</td>
                            </tr>
                            <tr>
                                <td>Fatih Yilmaz</td>
                                <td>fyilmaz</td>
                                <td>fatih@example.com</td>
                                <td>NihaiYonetici</td>
                            </tr>
                        </tbody>
                    </table>
                    <small class="text-muted">
                        <strong>Not:</strong> Kullanıcı Adı Excel'den alınır. Sadece harf, rakam, nokta (.) ve alt çizgi (_) kullanabilirsiniz.<br>
                        Varsayılan Şifre: <strong>Sifre123!</strong> (Kullanıcı ilk girişte değiştirebilir)<br>
                        <strong>Kapasitesi: Aynı anda 500 kişi sisteme alabilir.</strong>
                    </small>
                </div>
            </div>
        </div>
    }

    @if (Model.PreviewReady)
    {
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">2. Önizleme ve Kontrol</h5>
            </div>
            <div class="card-body">
                @if (Model.PreviewRows.Count == 0)
                {
                    <div class="alert alert-warning">Önizleme için satır bulunamadı.</div>
                }
                else
                {
                    <div class="mb-3">
                        <span class="badge bg-dark">Toplam: @Model.PreviewRows.Count</span>
                        <span class="badge bg-success">Geçerli: @Model.PreviewRows.Count(r => !r.Errors.Any())</span>
                        <span class="badge bg-danger">Hatalı: @Model.PreviewRows.Count(r => r.Errors.Any())</span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-sm table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Satır</th>
                                    <th>Ad</th>
                                    <th>Kullanıcı Adı</th>
                                    <th>Email</th>
                                    <th>Rol</th>
                                    <th>Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Model.PreviewRows)
                                {
                                    <tr class="@(row.Errors.Any() ? "table-danger" : "")">
                                        <td>@row.RowNo</td>
                                        <td>@row.Ad</td>
                                        <td><code>@row.KullaniciAdi</code></td>
                                        <td>@row.Email</td>
                                        <td><span class="badge bg-info">@row.RolStr</span></td>
                                        <td>
                                            @if (row.Errors.Any())
                                            {
                                                <span class="badge bg-danger">HATA</span>
                                                <br />
                                                <small class="text-danger">@string.Join(" | ", row.Errors)</small>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">OK</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="mt-3">
            @if (Model.CanImport)
            {
                <form method="post" asp-action="ImportExecute" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Girişi Onayla ve Tamamla
                    </button>
                </form>
            }
            else
            {
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> Hatalı satırlar var. Lütfen Excel'i düzeltip yeniden yükleyin.
                </div>
            }
            <a asp-action="Import" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Başa Dön
            </a>
        </div>
    }
</div>
