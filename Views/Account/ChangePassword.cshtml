@model PerformansSitesi.Web.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Şifre Değiştir";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Şifre Değiştir</h5>
            </div>
            <div class="card-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> @TempData["Success"]
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.Error))
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle"></i> @Model.Error
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label" asp-for="MevcutSifre">Mevcut Şifre</label>
                        <input class="form-control" type="password" asp-for="MevcutSifre" autocomplete="current-password" required />
                        <span class="text-danger" asp-validation-for="MevcutSifre"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="YeniSifre">Yeni Şifre</label>
                        <input class="form-control" type="password" asp-for="YeniSifre" autocomplete="new-password" required />
                        <span class="text-danger" asp-validation-for="YeniSifre"></span>
                        <small class="form-text text-muted">En az 4 karakter olmalıdır.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label" asp-for="YeniSifreTekrar">Yeni Şifre (Tekrar)</label>
                        <input class="form-control" type="password" asp-for="YeniSifreTekrar" autocomplete="new-password" required />
                        <span class="text-danger" asp-validation-for="YeniSifreTekrar"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-key"></i> Şifreyi Değiştir
                        </button>
                        <a class="btn btn-outline-secondary" asp-controller="Dashboard" asp-action="Index">İptal</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="mt-3">
            <div class="card">
                <div class="card-body">
                    <h6 class="card-title"><i class="bi bi-info-circle"></i> Güvenlik İpuçları</h6>
                    <ul class="small mb-0">
                        <li>Şifrenizi kimseyle paylaşmayın</li>
                        <li>Güçlü bir şifre seçin (harf, rakam, özel karakter)</li>
                        <li>Şifrenizi düzenli olarak değiştirin</li>
                        <li>Farklı sistemlerde farklı şifreler kullanın</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
